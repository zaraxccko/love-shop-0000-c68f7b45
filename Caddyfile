# ============================================================
# Edge reverse-proxy для любого домена из env.
# Caddy сам выпускает сертификат (ZeroSSL, затем Let's Encrypt fallback).
# Запускается как сервис `proxy` в docker-compose.
# ============================================================

{$APP_DOMAINS} {
	encode gzip zstd

	# API → backend
	handle /api/* {
		reverse_proxy api:3000
	}

	# Загрузки фото-подтверждений
	handle /uploads/* {
		reverse_proxy api:3000
	}

	# Всё остальное → фронт (SPA)
	handle {
		header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
		header Pragma "no-cache"
		header Expires "0"
		reverse_proxy frontend:80
	}

	log {
		output stdout
		format console
	}
}
